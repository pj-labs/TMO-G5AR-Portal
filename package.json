{
  "name": "tmo-g5ar-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:api\" \"pnpm run dev:client\"",
    "dev:client": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build && pnpm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist-server/index.mjs",
    "start": "NODE_ENV=production node dist-server/index.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@tanstack/react-router": "^1.114.3",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tanstack/router-devtools": "^1.114.3",
    "@tanstack/router-plugin": "^1.114.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.0.7"
  }
}
